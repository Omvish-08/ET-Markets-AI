{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The user's profile picture URL"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created"
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "PortfolioHolding": {
      "title": "Portfolio Holding",
      "description": "A stock holding in a user's portfolio",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "name": { "type": "string" },
        "shares": { "type": "number" },
        "avgPrice": { "type": "number" }
      },
      "required": ["symbol", "name", "shares", "avgPrice"]
    },
    "WatchlistItem": {
      "title": "Watchlist Item",
      "description": "A stock in a user's watchlist",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "name": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "name", "addedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles"
    },
    "/users/{userId}/portfolio/{holdingId}": {
      "schema": {
        "$ref": "#/entities/PortfolioHolding"
      },
      "description": "Stores user's portfolio holdings"
    },
    "/users/{userId}/watchlist/{watchlistItemId}": {
      "schema": {
        "$ref": "#/entities/WatchlistItem"
      },
      "description": "Stores user's watchlist items"
    }
  }
}
